# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database (PostgreSQL with PostGIS)
DATABASE_URL=postgres://user:password@host:5432/floodguard
DB_NAME=floodguard
DB_USER=postgres
DB_PASSWORD=your-secure-db-password
DB_HOST=db
DB_PORT=5432
DB_SSL_REQUIRE=False

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_SSL_CERT_REQS=required

# Africa's Talking SMS API (required for SMS alerts)
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key
SMS_ENABLED=True

# Multi-source flood intelligence APIs
OPENWEATHER_API_KEY=your_openweather_api_key
TOMORROW_IO_API_KEY=your_tomorrow_io_api_key
WEATHERAPI_KEY=your_weatherapi_key
NASA_EARTHDATA_TOKEN=your_nasa_earthdata_token
GEE_SERVICE_ACCOUNT_KEY_PATH=/path/to/gee_service_account.json

# AI analysis and chatbot
GROQ_API_KEY=your_groq_api_key

# Email Configuration (for email alerts)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email_user
EMAIL_HOST_PASSWORD=your_email_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=FloodGuard <noreply@floodguard.com>

# Security (for production)
SECURE_SSL_REDIRECT=True
CSRF_TRUSTED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com
